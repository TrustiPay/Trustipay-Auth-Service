NODE_ENV=development
PORT=3001
SERVICE_NAME=trustipay-auth-service

DATABASE_URL=file:../data/trustipay_auth.sqlite
AUTH_ISSUER_URL=http://localhost:3001/auth
AUTH_ACCESS_TOKEN_AUDIENCE=trustipay-api
AUTH_INTERNAL_TOKEN_AUDIENCE=trustipay-internal-api

AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_ID_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_AUTH_CODE_TTL_SECONDS=300

AUTH_TOKEN_HASH_SECRET=replace-with-strong-random-secret
AUTH_PASSWORD_PEPPER=

# Use PEM values with escaped newlines, or point to files with AUTH_JWT_PRIVATE_KEY_PATH/AUTH_JWT_PUBLIC_KEY_PATH.
AUTH_JWT_KID=trustipay-auth-dev-rs256
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_PUBLIC_KEY=
AUTH_JWT_PRIVATE_KEY_PATH=./keys/private.pem
AUTH_JWT_PUBLIC_KEY_PATH=./keys/public.pem

AUTH_ANDROID_CLIENT_ID=trustipay-android
AUTH_ANDROID_REDIRECT_URIS=trustipay://oauth/callback,https://app.trustipay.example/oauth/callback
AUTH_ALLOWED_ORIGINS=*

AUTH_ANALYTICS_CLIENT_SECRET=analytics-dev-secret
AUTH_OFFLINE_SERVICE_CLIENT_SECRET=offline-payment-dev-secret

AUTH_DEV_RETURN_CODES=true
AUTH_DEV_OAUTH_PASSWORD_AUTHORIZE=true
AUTH_FEATURE_MFA_ENABLED=false
AUTH_FEATURE_PASSKEYS_ENABLED=false
AUTH_FEATURE_DPOP_ENABLED=false
